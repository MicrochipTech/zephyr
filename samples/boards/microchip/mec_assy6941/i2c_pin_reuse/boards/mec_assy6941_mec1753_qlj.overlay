/ {
	aliases {
		i2c0 = &i2c_smb_0;
	};

	zephyr,user {
		i2c-port0-gpios = <MCHP_GPIO_DECODE_003 GPIO_ACTIVE_HIGH>,
				  <MCHP_GPIO_DECODE_004 GPIO_ACTIVE_HIGH>;

/*		pinctrl-0 = <&i2c00_sda_gpio003 &i2c00_scl_gpio004>; */
	};
};

