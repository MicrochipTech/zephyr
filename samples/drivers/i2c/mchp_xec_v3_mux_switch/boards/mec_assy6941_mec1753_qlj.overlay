 *
 * Overlay enabling the MEC5 I2C Network-Layer controller on i2c_smb_0
 * with two MUX child ports on distinct SCL/SDA pin pairs and distinct
 * clock frequencies, so the MUX has something to switch between.
 *
 * The DMA trigger-source numbers below (the second cell of each `dmas`
 * entry) are SoC-specific. Confirm against the MEC1753 reference manual
 * before wiring to real hardware; the values here follow the typical
 * MEC5 convention where the four I2C_SMB0 endpoints occupy the first
 * contiguous run of DMA device IDs.
 */

#include <zephyr/dt-bindings/dma/mchp_xec_cdma.h>
#include <zephyr/dt-bindings/i2c/i2c.h>

&cdma {
	status = "okay";
};

&i2c_smb_0 {
	compatible = "microchip,xec-i2c-v3-nl";
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	buffer-size = <64>;

	/* <&dmac CHANNEL TRIGSRC>, order must be host-tx-rx,
	 * target-tx-rx, (matches dma-names below).
	 */
	dmas = <&cdma 0  MCHP_XEC_DMA_I2C0_HOST>,
	       <&cdma 1  MCHP_XEC_DMA_I2C0_TARG>;
	dma-names = "host-tx-rx", "target-tx-rx";

	i2c_p0: i2c-port@0 {
		compatible = "microchip,xec-i2c-v3-port";
		reg = <0>;
		port = <MCHP_XEC_I2C_CTRL_PORT(0, 0)>;
		controller = <&i2c_smb_0>;
		clock-frequency = <I2C_BITRATE_STANDARD>;
		pinctrl-0 = <&i2c00_scl_gpio004 &i2c00_sda_gpio003>;
		pinctrl-names = "default";
		status = "okay";
	};

	i2c_p4: i2c-port@4 {
		compatible = "microchip,xec-i2c-v3-port;
		reg = <0>;
		port = <MCHP_XEC_I2C_CTRL_PORT(0, 4)>;
		controller = <&i2c_smb_0>;
		clock-frequency = <I2C_BITRATE_STANDARD>;
		pinctrl-0 = <&i2c04_sda_gpio143 &i2c04_scl_gpio144>;
		pinctrl-names = "default";
		status = "okay";
	};

	i2c_p5: i2c-port@5 {
		compatible = "microchip,xec-i2c-v3-port;
		reg = <0>;
		port = <MCHP_XEC_I2C_CTRL_PORT(0, 5)>;
		controller = <&i2c_smb_0>;
		clock-frequency = <I2C_BITRATE_STANDARD>;
		pinctrl-0 = <&i2c05_sda_gpio141 &i2c05_scl_gpio142>;
		pinctrl-names = "default";
		status = "okay";
	};
};
