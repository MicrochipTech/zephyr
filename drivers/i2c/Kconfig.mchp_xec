# Microchip XEC I2C configuration options

# Copyright (c) 2019 Intel Corporation
# SPDX-License-Identifier: Apache-2.0

config I2C_XEC
	bool "XEC Microchip I2C driver"
	default y
	depends on DT_HAS_MICROCHIP_XEC_I2C_ENABLED
	select PINCTRL
	help
	  Enable the Microchip XEC I2C driver.

config I2C_XEC_V2
	bool "XEC Microchip I2C driver"
	default y
	depends on DT_HAS_MICROCHIP_XEC_I2C_V2_ENABLED
	select PINCTRL
	help
	  Enable the Microchip XEC I2C V2 driver.

config I2C_MCHP_XEC_V3
	bool "Microchip XEC I2C v3 driver"
	default y
	depends on DT_HAS_MICROCHIP_XEC_I2C_V3_ENABLED
	depends on SOC_SERIES_MEC174X || SOC_SERIES_MEC175X || SOC_SERIES_MEC165XB
	select PINCTRL
	help
	  Microchip XEC I2C v3 controller driver. Supports MEC174x, MEC175x,
	  MEC165xB, and newer SoCs (all v3.8+ I2C_SMB hardware). Does not
	  support MEC15xx or MEC172x. Uses interrupt-driven byte-mode transfers
	  for both controller and target modes, supports two target addresses,
	  and supports port switching with per-port frequency via a companion
	  port driver bound to compatible "microchip,xec-i2c-v3-port".

config I2C_MCHP_XEC_V3_PORT_INIT_PRIORITY
	int "Microchip XEC I2C v3 port init priority"
	default 51
	depends on I2C_MCHP_XEC_V3
	help
	  Initialization priority for the I2C v3 port driver. Must be greater
	  than CONFIG_I2C_INIT_PRIORITY so that the controller device exists
	  when the port driver dereferences its "controller" phandle during
	  init. The port driver applies pinctrl before enabling the controller,
	  which the Microchip hardware requires.

# Note: target-mode receive buffer size is set per-controller via the
# "target-buffer-size" DT property on each microchip,xec-i2c-v3 node
# (default 32 bytes if unspecified). Setting it in DT rather than Kconfig
# lets applications tune the buffer per I2C_SMB controller instance.

if I2C_MCHP_XEC_V3

config I2C_MCHP_XEC_V3_INSTRUMENT_ISR
	bool "Microchip XEC I2C v3 driver instrumentation"
	help
	  Add instrumentation to the driver

config I2C_MCHP_XEC_V3_INSTRUMENT_ISR_ENTRIES
	int "Microchip XEC I2C v3 driver instrumentation number of entries"
	default 256
	depends on I2C_MCHP_XEC_V3_INSTRUMENT_ISR
	help
	  The number of entries in instrumentation array.

config I2C_MCHP_XEC_V3_INSTRUMENT_STATE
	bool "Microchip XEC I2C v3 driver state instrumentation"
	help
	  Add code flow instrumentation

config I2C_MCHP_XEC_V3_INSTRUMENT_STATE_ENTRIES
	int "Microchip XEC I2C v3 driver instrument states"
	default 1024
	depends on I2C_MCHP_XEC_V3_INSTRUMENT_STATE
	help
	  The number of states which can be saved

endif #I2C_MCHP_XEC_V3
