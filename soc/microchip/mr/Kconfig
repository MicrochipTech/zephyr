	# is configured. Standard pattern used by in-tree SoC families.
	select HAS_SEGGER_RTT if ZEPHYR_SEGGER_MODULE

if SOC_FAMILY_MICROCHIP_MR

# Pull in the per-series hardware Kconfig (CPU/arch selects).
rsource "*/Kconfig"

endif # SOC_FAMILY_MICROCHIP_MR
