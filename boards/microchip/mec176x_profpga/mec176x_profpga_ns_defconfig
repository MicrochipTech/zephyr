# Non-Secure configuration for TF-M integration

# TrustZone configuration
CONFIG_ARM_TRUSTZONE_M=y

# TF-M configuration
CONFIG_TFM_BL2=n
# NOTE: TF-M model (SFN vs IPC) is an application choice - set it in the
# sample/app prj.conf (CONFIG_TFM_IPC / CONFIG_TFM_SFN), not here.
CONFIG_ARM_MPU=y
CONFIG_RUNTIME_NMI=y

# FPU configuration (required for TF-M with Cortex-M55)
CONFIG_FPU=y
CONFIG_FP_HARDABI=y

# Console
CONFIG_CONSOLE=y

# Serial - XEC UART driver + pin muxing
CONFIG_SERIAL=y
CONFIG_PINCTRL=y
CONFIG_UART_INTERRUPT_DRIVEN=n

# TEMPORARY: console over SEGGER RTT (UART pins not routed in current FPGA bitstream)
CONFIG_UART_CONSOLE=n
CONFIG_USE_SEGGER_RTT=y
CONFIG_RTT_CONSOLE=y
