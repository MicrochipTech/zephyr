CONFIG_CONSOLE=y

# XEC UART driver + pin muxing (binds via DT). Kept enabled so the UART is brought
# up and ready; first bring-up is polled-only (no ECIA/GIRQ15 interrupt path yet).
CONFIG_SERIAL=y
CONFIG_PINCTRL=y
CONFIG_UART_INTERRUPT_DRIVEN=n

# TEMPORARY: console over SEGGER RTT (live, over the JTAG probe) because the UART
# pins (GPIO104/105) are NOT yet routed to pads on the current FPGA bitstream.
# When the pads are routed, REVERT to the UART console: set CONFIG_UART_CONSOLE=y
# and drop the three RTT lines below.
CONFIG_UART_CONSOLE=n
CONFIG_USE_SEGGER_RTT=y
CONFIG_RTT_CONSOLE=y
